{
  "manifest_version": 3,
  "name": "Now Extension for Claude",
  "version": "0.1.0",
  "description": "Automatically adds the current date and time to your messages on Claude.ai, giving Claude real temporal context.",
  "permissions": ["storage"],
  "host_permissions": ["https://claude.ai/*"],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Now Extension"
  }
}